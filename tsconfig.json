{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2024"],
        "strict": true,
        "noUncheckedIndexedAccess": false,
        "skipLibCheck": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "types": ["node"]
    },
    "include": ["src"]
}

